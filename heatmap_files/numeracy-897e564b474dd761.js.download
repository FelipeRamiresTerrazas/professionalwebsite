        GROUP BY lof.account_name
        ORDER BY finding_count DESC
        `,bindingsJSON:[r,r]},role:e,isInternal:!0,desc:"trust-center-org-top-violations",...t&&{warehouse:t},feature:hq}))({role:e,warehouse:t,currentAccountName:r}))}}async trustCenterOrgViolationsByScannerPackage({role:e,warehouse:t,currentAccountName:r}){return{result:await this.sqlQueryBackend.query((({role:e,warehouse:t,currentAccountName:r})=>({sqlQuery:{sqlText:`
        WITH combined_findings AS (
          SELECT
                account_name,
                f.scanner_package_id,
                f.scanner_id,
                f.state,
                severity,
                updated_on,
                (UPPER(f.state) in ('OPEN', 'RESOLVED MANUALLY', 'MUTED')) as included,
            FROM snowflake.organization_usage.trust_center_findings f
            LEFT JOIN snowflake.trust_center.scanners s
              ON f.scanner_package_id = s.scanner_package_id
              AND f.scanner_id = s.id
            WHERE true
              AND account_name != ?
              AND s.description IS NOT NULL
              AND s.short_description IS NOT NULL
            UNION ALL
            SELECT
                ? as account_name,
                scanner_package_id,
                scanner_id,
                state,
                severity,
                end_timestamp as updated_on,
                total_at_risk_count > 0 as included,
            FROM snowflake.trust_center.findings
            WHERE scanner_type = 'Vulnerability'
        ),
        latest_org_findings AS (
          SELECT
            scanner_package_id,
            scanner_id,
            account_name,
            updated_on,
            included,
            state,
            ROW_NUMBER() OVER (
              PARTITION BY account_name, scanner_package_id, scanner_id
              ORDER BY updated_on DESC NULLS LAST
            ) as rn
          FROM combined_findings
          WHERE account_name IS NOT NULL
        )
        SELECT
          sp.name as scanner_package,
