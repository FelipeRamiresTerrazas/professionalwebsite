Follow these steps:
Step 1 — Ask me about myself:
- What's my role? (e.g., analyst, data engineer, ML engineer, app developer)
- Which part of the business do I work with most? (e.g., Finance, Marketing, Product, Sales, Operations)
- What does my day-to-day look like? (dashboards, pipelines, models, ad-hoc analysis, etc.)
- What tools am I comfortable with? (SQL, Python, dbt, Streamlit, etc.)
- Any specific project or goal I'm starting with?

Step 2 — Discover my Snowflake environment: Query Snowflake to find my current role, privileges, accessible databases/schemas, and relevant objects based on my answers.
Query Snowflake to find my current role, privileges, accessible databases/schemas, and relevant objects based on my answers.

Step 3 — Give me a personalized getting-started plan:
- What I have access to (roles, warehouses, key data)
- Objects to explore first, based on my business area
- Snowflake features relevant to my work
- Quick wins and first tasks I can try right now
- How Cortex Code can help me move faster

Keep it friendly, practical, and matched to my experience level.`,"connect-catalog":"Connect to an external catalog"},mV="prompt-id",mD=e=>{var t;return null!=(t=mF[e])?t:null};var mG=r(310398);let mP={kZKoxP:"blt-1dr59a3",kVQacm:"blt-b3r6kr",kzqmXN:"blt-h8yej3",$$css:!0},mB={kZKoxP:"blt-5yr21d",kzqmXN:"blt-h8yej3",kVQacm:"blt-b3r6kr",$$css:!0},mM=()=>{document.querySelectorAll("iframe").forEach(e=>{e.style.pointerEvents="none"})},mU=()=>{document.querySelectorAll("iframe").forEach(e=>{e.style.pointerEvents="auto"});try{requestAnimationFrame(()=>window.dispatchEvent(new CustomEvent("pep-right-panel-resize-end")))}catch(e){}};function mj(){let e=document.getElementById("right-panel");if(!e){try{requestAnimationFrame(()=>window.dispatchEvent(new CustomEvent("pep-right-panel-resize-end")))}catch(e){}return}let t=!1,r=a=>{t=!0,e.removeEventListener("transitionend",r);try{window.dispatchEvent(new CustomEvent("pep-right-panel-resize-end"))}catch(e){}};e.addEventListener("transitionend",r,{once:!0}),window.setTimeout(()=>{if(!t){e.removeEventListener("transitionend",r);try{window.dispatchEvent(new CustomEvent("pep-right-panel-resize-end"))}catch(e){}}},300)}function mW({leftPanelRef:e,panelOpenTimeRef:t,logPanelClosed:r,currentPayload:a,isContentVisible:n}){let[,s]=mx(),i=(0,pw.useCallback)(()=>{let e=null!==t.current?Date.now()-t.current:void 0;void 0!==e?r({sessionDuration:e}):r(),t.current=null,s(null),mj()},[s,r,t]);return(0,eu.jsx)(p_.s,{direction:"column",stylex:mB,gap:"0x",children:(0,eu.jsx)("div",{...{0:{className:"blt-1n2onr6 blt-5yr21d blt-h8yej3 blt-1odjw0f blt-g01cxk blt-17gemzt"},1:{className:"blt-1n2onr6 blt-5yr21d blt-h8yej3 blt-1odjw0f blt-1hc1fzr blt-op05o2"}}[0|!!n],children:a?a.type===mg.HP.Copilot?(0,eu.jsx)(eC.C,{dismissRightPanel:i,leftPanelRef:e}):void 0:null})})}function mZ({leftPanelRef:e,denyAccessToRightPanel:t,panelOpenTimeRef:r,logPanelClosed:a,currentPayload:n,isContentVisible:s}){return t?null:(0,eu.jsx)(mW,{leftPanelRef:e,panelOpenTimeRef:r