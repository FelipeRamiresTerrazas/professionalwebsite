capacity_balances as (
select 
  contract_number, 
  date,
  greatest(coalesce(free_usage_balance, 0), 0) as free_usage_balance,
  greatest(coalesce(capacity_balance, 0), 0) as capacity_balance,
  greatest(coalesce(rollover_balance, 0), 0) as rollover_balance,
  row_number() over (partition by contract_number order by date desc) as row_num,
  currency
