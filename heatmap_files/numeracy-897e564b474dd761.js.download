                WHERE FINDING_IDENTIFIER = ?;`,bindingsJSON:[r]},role:e,isInternal:!0,desc:"trust-center-finding-activity-history",...t&&{warehouse:t},feature:hq})}}async trustCenterFindingComments({role:e,warehouse:t,finding_id:r}){return{result:await this.sqlQueryBackend.query({sqlQuery:{sqlText:`
