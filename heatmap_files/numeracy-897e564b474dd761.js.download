        FROM latest_org_findings lof
        LEFT JOIN snowflake.trust_center.scanner_packages sp
          ON lof.scanner_package_id = sp.id
        WHERE lof.rn = 1 and lof.included = true and UPPER(lof.state) = 'OPEN'
        GROUP BY sp.name, lof.account_name
        `,bindingsJSON:[r,r]},role:e,isInternal:!0,desc:"trust-center-org-violations-by-scanner-package",...t&&{warehouse:t},feature:hq}))({role:e,warehouse:t,currentAccountName:r}))}}async trustCenterOrgFindings({role:e,warehouse:t,currentAccountName:r}){return{result:await this.sqlQueryBackend.query((({role:e,warehouse:t,currentAccountName:r})=>({sqlQuery:{sqlText:`
        WITH combined_findings AS (
         SELECT
                id,
                account_name,
                scanner_package_id,
                scanner_id,
                state,
                severity,
                updated_on,
                (UPPER(state) in ('OPEN', 'RESOLVED MANUALLY', 'MUTED')) as included,
            FROM snowflake.organization_usage.trust_center_findings
            WHERE account_name != ?
            UNION ALL
            SELECT
                event_id as id,
                ? as account_name,
                scanner_package_id,
                scanner_id,
                state,
                severity,
                end_timestamp as updated_on,
                total_at_risk_count > 0 as included,
            FROM snowflake.trust_center.findings
            WHERE scanner_type = 'Vulnerability'
        ),
        latest_account_findings AS (
          SELECT
            scanner_package_id,
            scanner_id,
            suggested_action,
            impact,
            ROW_NUMBER() OVER (
              PARTITION BY scanner_package_id, scanner_id
              ORDER BY start_timestamp DESC NULLS LAST, created_on DESC
            ) as rn
          FROM snowflake.trust_center.findings
          WHERE completion_status = 'SUCCEEDED'
        ),
        latest_org_findings AS (
          SELECT
            id,
            scanner_package_id,
            scanner_id,
            account_name,
            severity,
            updated_on,
            state,
            included,
            ROW_NUMBER() OVER (
              PARTITION BY account_name, scanner_package_id, scanner_id
              ORDER BY updated_on DESC NULLS LAST
            ) as rn
          FROM combined_findings
          WHERE account_name IS NOT NULL
        )
        SELECT
          ofv.id as event_id,
          ofv.scanner_package_id as scanner_package_id,
          ofv.scanner_id as scanner_id,
          ofv.account_name as account_name,
          ofv.severity as severity,
          ofv.state as state,
          ofv.updated_on as updated_on,
          s.name as scanner_name,
          s.short_description as scanner_short_description,
          s.description as scanner_description,
          sp.name as scanner_package_name,
          f.suggested_action as suggested_action,
          f.impact as impact
        FROM latest_org_findings ofv
        LEFT JOIN snowflake.trust_center.scanners s
            ON ofv.scanner_package_id = s.scanner_package_id AND ofv.scanner_id = s.id
        LEFT JOIN snowflake.trust_center.scanner_packages sp
            ON ofv.scanner_package_id = sp.id
        LEFT JOIN latest_account_findings f
            ON ofv.scanner_package_id = f.scanner_package_id
            AND ofv.scanner_id = f.scanner_id
            AND f.rn = 1
